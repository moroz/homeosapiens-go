{{define "content"}}
{{- /*gotype: github.com/moroz/homeosapiens-go/tmpl/email.EventRegistrationEmailProps*/ -}}

    <h2 style="margin: 0 0 16px; text-align: center">{{.T "emails.event_registration_confirmation.heading"}}</h2>

    {{.Translate "emails.user_opening_html" .Data.User}}

    <p>{{.Translate "emails.event_registration_confirmation.body" .Data}}</p>

    <table width="100%" cellpadding="0" cellspacing="0" border="0" style="margin: 24px 0; border: 1px solid #e0e0e0; border-radius: 4px;">
        <tr>
            <td style="padding: 16px;">
                <p style="margin: 0 0 8px; font-size: 18px; font-weight: bold;">{{.Data.Title}}</p>
                <p style="margin: 0 0 4px; color: #555555;">
                    <strong>{{.T "emails.event_registration_confirmation.date"}}</strong>
                    {{.Data.FormattedStartsAt}}
                </p>
                {{if .Data.IsVirtual}}
                <p style="margin: 0; color: #555555;">
                    <strong>{{.T "emails.event_registration_confirmation.location"}}</strong>
                    {{.T "emails.event_registration_confirmation.online"}}
                </p>
                {{else if .Data.VenueAddress}}
                <p style="margin: 0; color: #555555;">
                    <strong>{{.T "emails.event_registration_confirmation.location"}}</strong>
                    {{.Data.VenueAddress}}
                </p>
                {{end}}
            </td>
        </tr>
    </table>

    <p style="text-align: center;">
        <a href="{{.Data.EventURL}}"
           target="_blank"
           rel="noopener noreferrer"
           style="display: inline-block; padding: 12px 24px; background-color: #2d6a4f; color: #ffffff; text-decoration: none; border-radius: 4px; font-weight: bold;">
            {{.T "emails.event_registration_confirmation.view_event"}}
        </a>
    </p>

{{end}}
